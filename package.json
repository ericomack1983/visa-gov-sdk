{
  "name": "@visa-gov/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Visa Government Procurement — VCN issuance, multi-rail settlement, and AI-powered supplier matching",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "visa-gov-mcp": "./mcp/dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "example:payments": "npx ts-node --esm examples/payments.ts",
    "example:procurement": "npx ts-node --esm examples/procurement.ts",
    "build:mcp": "tsup --config tsup.mcp.config.ts",
    "start:mcp": "node mcp/dist/index.js",
    "dev:mcp": "tsx mcp/index.ts",
    "build:mcp:b2b": "tsup --config tsup.mcp-b2b.config.ts",
    "start:mcp:b2b": "node mcp/b2b/dist/server.js",
    "dev:mcp:b2b": "tsx mcp/b2b/server.ts"
  },
  "keywords": [
    "visa",
    "vcn",
    "virtual-card",
    "government",
    "procurement",
    "settlement",
    "supplier-matching",
    "ai",
    "typescript",
    "sdk"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@visa-gov/sdk": "github:ericomack1983/visa-gov-sdk",
    "zod": "^4.3.6"
  }
}
